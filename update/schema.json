{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DancingMusic/Release/blob/main/update/schema.json",
  "title": "DancingMusic update manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "channel", "version", "publishedAt", "artifacts"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "channel": { "enum": ["stable", "beta"] },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "releaseNotesUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
    "artifacts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "sha256", "size", "urls"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size": { "type": "integer", "minimum": 1 },
          "urls": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "format": "uri", "pattern": "^https://" }
          },
          "signature": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "file", "sha256", "size", "urls", "fingerprint", "publicKey"],
            "properties": {
              "type": { "const": "openpgp-detached" },
              "file": { "type": "string", "pattern": "\\.asc$" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "size": { "type": "integer", "minimum": 1 },
              "urls": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": { "type": "string", "format": "uri", "pattern": "^https://" }
              },
              "fingerprint": { "type": "string", "pattern": "^(?:[A-F0-9]{40}|[A-F0-9]{64})$" },
              "publicKey": {
                "type": "object",
                "additionalProperties": false,
                "required": ["file", "sha256", "size", "urls"],
                "properties": {
                  "file": { "type": "string", "minLength": 1 },
                  "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                  "size": { "type": "integer", "minimum": 1 },
                  "urls": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": { "type": "string", "format": "uri", "pattern": "^https://" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
